## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015 cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# =============================================================================
# Environment variables — NEVER commit secrets
# =============================================================================
.env
.env.local
.env.development
.env.production
.env.docker
*.env

# Keep example/template files
!.env.example
!env.example

# =============================================================================
# Database
# =============================================================================
*.db
*.sqlite
*.sqlite3

# Database backups & dumps
*.sql
*.dump
backup/
backups/

# =============================================================================
# Logs
# =============================================================================
[Ll]ogs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# Docker
# =============================================================================
.docker/
docker-compose.override.yml

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.temp
*~

# Local .NET CLI / SDK caches created during local builds
.dotnet/
.dotnet-cli/

# =============================================================================
# User secrets & sensitive config
# =============================================================================
secrets.json
# Keep base appsettings and Development overrides; ignore all others
appsettings.*.json
!appsettings.json
!appsettings.Development.json

# Private keys and certificates
*.pfx
*.p12
*.key
*.pem

# =============================================================================
# Test results
# =============================================================================
TestResults/
*.trx
*.coverage

# =============================================================================
# NuGet
# =============================================================================
*.nupkg
*.snupkg
.nuget/
packages/

# =============================================================================
# Publish artifacts
# =============================================================================
PublishProfiles/
*.pubxml
*.azurePubxml

# Application Insights
ApplicationInsights.config

# =============================================================================
# Runtime data — should not be version-controlled
# =============================================================================
# Uploaded files (persisted via Docker volume at runtime)
**/uploads/
**/wwwroot/uploads/

# Backup files
*.bak

# Node modules (if any frontend tooling is added)
node_modules/
