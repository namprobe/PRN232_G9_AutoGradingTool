# Sample Base Environment Configuration
# Copy this to .env and customize for your environment
# This file should be committed to version control with safe defaults

# =============================================================================
# Docker Compose Port Configuration
# =============================================================================
# Ports exposed on host machine (format: HOST_PORT:CONTAINER_PORT)
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050
API_PORT=5000
# CMS React (nginx trong container) map ra host — mặc định 5173 khớp CORS/README
FRONTEND_PORT=5173

# =============================================================================
# PostgreSQL Configuration (for Docker containers)
# =============================================================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=postgres_db
POSTGRES_MULTIPLE_DATABASES=autogradingtool_db,autogradingtool_outerdb

# Database host for API entrypoint (wait-for-db). Trong Docker Compose = tên service.
# docker compose: postgres | dotnet run máy local: localhost
DB_HOST=postgres
DB_PORT=5432

# Connection strings (ASP.NET Core: __ → :)
# --- docker compose: bắt buộc Host=postgres; Username/Password khớp POSTGRES_* bên trên ---
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=autogradingtool_db;Username=admin;Password=admin@123;
ConnectionStrings__OuterDbConnection=Host=postgres;Port=5432;Database=autogradingtool_outerdb;Username=admin;Password=admin@123;
# --- dotnet run trên máy (không Docker): đổi Host=localhost và giữ cùng user/pass local ---

# =============================================================================
# Application Configuration
# =============================================================================
ASPNETCORE_ENVIRONMENT=Development

# =============================================================================
# Localization Configuration
# =============================================================================
# Supported cultures (comma-separated): en,vi,th,id,zh,etc.
# Default: en,vi
Localization__SupportedCultures=en,vi
# Default culture (fallback language)
# Default: en
Localization__DefaultCulture=en

# =============================================================================
# JWT Settings
# =============================================================================
Jwt__Key=REPLACE_WITH_STRONG_JWT_KEY_AT_LEAST_32_CHARS
Jwt__Issuer=Autogradingtool
Jwt__Audience=AutogradingtoolClients
Jwt__ExpiresInMinutes=60
Jwt__RefreshTokenExpiresInDays=7

# =============================================================================
# Admin User Configuration
# =============================================================================
AdminUser__Email=admin@autogradingtool.com
AdminUser__DefaultPassword=Admin@123

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
Cors__AllowedOrigins=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:4200

# =============================================================================
# Redis Configuration
# =============================================================================
# Password for Redis container (used by docker-compose)
# Leave empty if Redis doesn't require password
# Example: REDIS_PASSWORD=YOUR_REDIS_PASSWORD
REDIS_PASSWORD=

# Redis connection string for application
# Format: host:port[,password=YOUR_PASSWORD]
# 
# Examples:
#   - Without password (local): localhost:6379
#   - With password (local): localhost:6379,password=YOUR_REDIS_PASSWORD
#   - Docker (without password): redis:6379
#   - Docker (with password): redis:6379,password=YOUR_REDIS_PASSWORD
#
# Note: If REDIS_PASSWORD is set above, use the same password here
# docker compose: redis | máy local không Docker: localhost:6379
REDIS__Configuration=redis:6379

# =============================================================================
# Hangfire Configuration
# =============================================================================
Hangfire__UseOuterDatabase=true
Hangfire__WorkerCount=2
Hangfire__NotificationBatchSize=1000
Hangfire__HeartbeatInterval=30
Hangfire__QueuePollInterval=15
Hangfire__CommandBatchMaxTimeout=300
Hangfire__SlidingInvisibilityTimeout=300
Hangfire__UseRecommendedIsolationLevel=true
Hangfire__DisableGlobalLocks=true
# Hangfire queues (comma-separated): queue1,queue2,queue3
# Auto grading requires "grading" queue for GradeSubmissionJob
Hangfire__Queues=notification-system,grading
Hangfire__Retry__Attempts=3
Hangfire__Retry__DelayInSeconds__First=60
Hangfire__Retry__DelayInSeconds__Second=300
Hangfire__Retry__DelayInSeconds__Third=600
Hangfire__Limits__MaxConcurrentJobsPerQueue=2
Hangfire__Limits__QueueTimeout=1800

# Hangfire Dashboard Settings
Hangfire__Dashboard__Title=PRN232_G9_AutoGradingTool Hangfire Dashboard
Hangfire__Dashboard__StatsPollingInterval=2000
Hangfire__Dashboard__DefaultRecordsPerPage=50
Hangfire__Dashboard__DisplayStorageConnectionString=false
Hangfire__Dashboard__EnableStatistics=true
Hangfire__Dashboard__EnableMetrics=true
Hangfire__Dashboard__Security__RequireAuthentication=false
Hangfire__Dashboard__Security__AllowAnonymous=true

# =============================================================================
# Email / SMTP Settings
# =============================================================================
EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__SmtpPort=587
EmailSettings__SenderEmail=your-email@gmail.com
EmailSettings__SenderPassword=YOUR_EMAIL_APP_PASSWORD
EmailSettings__EnableSsl=true
EmailSettings__SenderName=No Reply - AutoGradingTool

# =============================================================================
# Feature Flags
# =============================================================================
# Bật true lần đầu để có admin + dữ liệu demo exam grading
DataSeeding__EnableSeeding=true

# =============================================================================
# pgAdmin Configuration
# =============================================================================
# pgAdmin credentials (must be a valid email)
PGADMIN_DEFAULT_EMAIL=admin@autogradingtool.com
PGADMIN_DEFAULT_PASSWORD=Admin@123

# =============================================================================
# File Storage Configuration
# =============================================================================
FileStorage__ProviderType=LocalStorage
FileStorage__BaseUrl=
# 200MB mỗi file (zip Q1/Q2 có thể > 50MB)
FileStorage__MaxFileSizeBytes=209715200
FileStorage__AllowedExtensions=
FileStorage__Local__RootPath=uploads

# AWS S3 Configuration (if using S3 storage)
FileStorage__S3__BucketName=YOUR_S3_BUCKET_NAME
FileStorage__S3__Region=YOUR_AWS_REGION
FileStorage__S3__AccessKey=YOUR_AWS_ACCESS_KEY
FileStorage__S3__SecretKey=YOUR_AWS_SECRET_KEY
