		{
			"name": "7. Wait for Session End + Query",
			"item": [
				{
					"name": "List Submissions (after session ends)",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Wait until the exam session has ended (EndsAtUtc + small buffer)",
									"const endsEpoch = parseInt(pm.collectionVariables.get('session_ends_epoch'), 10);",
									"const now = Date.now();",
									"const waitMs = Math.max(0, endsEpoch - now + 5000);",
									"console.log('Waiting ' + (waitMs / 1000) + 's for session to end...');",
									"if (waitMs > 0) {",
									"    const start = Date.now();",
									"    while (Date.now() - start < waitMs) { /* busy wait */ }",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
									"const json = pm.response.json();",
