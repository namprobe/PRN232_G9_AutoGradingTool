		{
			"name": "6. Student Batch Submit",
			"item": [
				{
					"name": "Student Batch Submit Zips",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
									"pm.test('Response < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
									"const json = pm.response.json();",
									"pm.test('isSuccess is true', function () { pm.expect(json.isSuccess).to.be.true; });",
									"pm.test('successCount > 0', function () { pm.expect(json.data.successCount).to.be.above(0); });",
									"pm.test('failureCount is 0', function () { pm.expect(json.data.failureCount).to.eql(0); });",
									"pm.test('results array exists', function () { pm.expect(json.data.results).to.be.an('array').that.is.not.empty; });",
									"pm.test('first result is success', function () { pm.expect(json.data.results[0].success).to.be.true; });",
									"if (json.data && json.data.results && json.data.results[0].submissionId) {",
									"    pm.collectionVariables.set('submission_id', json.data.results[0].submissionId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
