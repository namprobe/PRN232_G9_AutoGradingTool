									"pm.collectionVariables.set('starts_at_utc', start.toISOString());",
									"pm.collectionVariables.set('ends_at_utc', end.toISOString());",
									"pm.collectionVariables.set('session_ends_epoch', end.getTime());",
									"pm.collectionVariables.set('session_code', 'SES_' + pm.collectionVariables.get('run_id'));"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
