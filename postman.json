							"raw": "{\n  \"code\": \"{{sem_code}}\",\n  \"name\": \"E2E Semester {{run_id}}\",\n  \"startDateUtc\": \"2026-01-01T00:00:00Z\",\n  \"endDateUtc\": \"2026-12-31T23:59:59Z\"\n}"
