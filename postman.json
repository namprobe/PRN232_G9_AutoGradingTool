		{
			"name": "2. Semester",
			"item": [
				{
					"name": "Create Semester",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// Generate a unique run ID to avoid conflicts on re-runs",
									"const runId = Date.now().toString(36).slice(-6);",
									"pm.collectionVariables.set('run_id', runId);",
									"pm.collectionVariables.set('sem_code', 'SEM_' + runId);",
									"pm.collectionVariables.set('student_code', 'HE' + Date.now().toString().slice(-6));"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status 200', function () { pm.response.to.have.status(200); });",
									"pm.test('Response < 2s', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
									"const json = pm.response.json();",
									"pm.test('isSuccess is true', function () { pm.expect(json.isSuccess).to.be.true; });",
									"pm.test('data.id exists', function () { pm.expect(json.data.id).to.be.a('string'); });",
									"pm.test('data.code matches', function () { pm.expect(json.data.code).to.eql(pm.collectionVariables.get('sem_code')); });",
									"pm.collectionVariables.set('semester_id', json.data.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"url": {
							"raw": "{{baseUrl}}/api/cms/grading/semesters",
